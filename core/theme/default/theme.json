{
    "id": "default",
    "name": "默认主题",
    "version": "1.5.4",
    "author": "misc-api",
    "description": "参考 FeerApi 前台 UI 完整复刻，白色主题色板；含粒子背景、终端 Hero、接口目录与在线调试",
    "preview": "preview.png",
    "settings": [
        {
            "key": "hero_title",
            "label": "首页主标题",
            "type": "text",
            "placeholder": "留空使用站点名称"
        },
        {
            "key": "hero_lead",
            "label": "首页副文案",
            "type": "textarea",
            "placeholder": "留空使用站点描述"
        },
        {
            "key": "show_partners",
            "label": "显示合作伙伴区",
            "type": "checkbox",
            "default": true
        },
        {
            "key": "show_runtime",
            "label": "显示网站运行时间",
            "type": "checkbox",
            "default": true
        },
        {
            "key": "show_footer_qr",
            "label": "显示页脚二维码",
            "type": "checkbox",
            "default": true
        }
    ]
}
